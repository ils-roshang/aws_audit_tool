# =============================================================================
# AWS Infrastructure Dashboard — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
#            The .gitignore already excludes it.
# =============================================================================


# -----------------------------------------------------------------------------
# AWS Credentials (REQUIRED)
# -----------------------------------------------------------------------------

# Your AWS access key ID (starts with AKIA or ASIA)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID

# Your AWS secret access key
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# Default region used for global API calls (e.g. Cost Explorer)
AWS_DEFAULT_REGION=us-east-1

# Friendly account name shown in report headers and cover page
# Example: "MyCompany-Production" or "Dev Account"
AWS_ACCOUNT_NAME=My AWS Account

# (Optional) Limit analysis to specific regions.
# Comma-separated. Leave blank to auto-discover all active regions.
# Example: AWS_REGIONS=us-east-1,eu-west-1,ap-southeast-1
# AWS_REGIONS=


# -----------------------------------------------------------------------------
# GCP / Vertex AI — Gemini 2.5 Pro (REQUIRED only for AI analysis)
# -----------------------------------------------------------------------------
# If you run with --no-ai these settings are ignored entirely.

# Absolute path to your GCP Service Account JSON key file.
# The service account must have the "Vertex AI User" role.
# Store this file OUTSIDE the repository directory for security.
# Windows example: C:\keys\my-gcp-key.json
# macOS/Linux example: /home/user/keys/my-gcp-key.json
GCP_SA_KEY_PATH=/path/to/your/service-account-key.json

# Your GCP project ID (found in the GCP Console dashboard)
GCP_PROJECT_ID=your-gcp-project-id

# GCP region for Vertex AI endpoint
GCP_LOCATION=us-central1

# (Optional) Override the Gemini model version.
# Default: gemini-2.5-pro
# GEMINI_MODEL=gemini-2.5-pro


# -----------------------------------------------------------------------------
# Advanced Settings (OPTIONAL — safe to leave as defaults)
# -----------------------------------------------------------------------------

# Enable Cloud Control API supplementary sweep (true/false).
# When true, discovers additional services like Glue, MSK, OpenSearch, WAF.
# Set to false if discovery is slow or you only need core services.
# CLOUDCONTROL_SWEEP=true
